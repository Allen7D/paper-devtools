{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["../extension/src/*"],
      "@example/*": ["../example/src/*"]
    }
  },
  "include": ["src", "../extension/src", "../example/src"]
}
