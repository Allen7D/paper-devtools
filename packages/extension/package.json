{
  "name": "extension",
  "version": "0.1.0",
  "description": "Chrome DevTools 扩展，用于调试 Paper.js 应用",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "run-p dev:*",
    "dev:chrome": "vite",
    "dev:inject": "vite build --config vite.inject.config.ts --watch --mode development",
    "build": "run-s build:*",
    "build:chrome": "tsc -b && vite build",
    "build:inject": "vite build --config vite.inject.config.ts",
    "preview": "vite preview"
  },
  "dependencies": {
    "@textea/json-viewer": "^4.0.1",
    "react-json-tree": "^0.20.0"
  }
}